NODE_ENV="development"
PORT="3000"

# Your frontend origin (must include https://)
FRONTEND_URL="https://crmcis.vercel.app"

# JWT signing secret (generate a strong random value)
JWT_SECRET="replace_me_with_a_strong_secret"

# Database connection strings
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Seed defaults (optional; used by `prisma db seed`)
SEED_DEFAULT_PASSWORD="replace_me"
SEED_SUPER_ADMIN_EMAIL="superadmin@example.com"
SEED_BRANCH_MANAGER_EMAIL="manager@example.com"
SEED_INVENTORY_OFFICER_EMAIL="officer@example.com"
